local doFire = function()
    if not LocalPlayer.Character then return end
    local cam = workspace.CurrentCamera; local ok, mouse = pcall(function() return UserInputService:GetMouseLocation() end)
    if not ok then return end
    local vec2 = { mouse.X, mouse.Y }; local eventData = {}
    if Alive then

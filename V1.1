local parriedBalls = {}

local function CombinedParryLoop()
        if autoParryEnabled and LocalPlayer.Character and LocalPlayer.Character.PrimaryPart then
        local balls = riverGetBalls()
        local trainingBall = nil
        if TrainingBalls then for _, v in ipairs(TrainingBalls:GetChildren()) do if v:GetAttribute("realBall") then trainingBall = v; break end end end

        for _, ball in ipairs(balls) do
            if not ball then continue end
            local zoomies = ball:FindFirstChild("zoomies"); if not zoomies then continue end

            local ballId = ball:GetDebugId()

            ball:GetAttributeChangedSignal("target"):Once(function()
                Sys.__parried = false; Sys.__antidot_parried = false
                parriedBalls[ballId] = nil
            end)

            if parriedBalls[ballId] then continue end

            local ballTarget = ball:GetAttribute("target")
            local velocity = zoomies.VectorVelocity; local distance = (LocalPlayer.Character.PrimaryPart.Position - ball.Position).Magnitude
            local ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue(); local pingThreshold = math.clamp(ping / 10, 5, 17)
            local speed = velocity.Magnitude; if speed <= 0 then continue end

            local cappedSpeedDiff = math.min(math.max(speed - 9.5, 0), 650)
            local speedDivisor = (2.5 + cappedSpeedDiff * 0.002) * Speed_Divisor_Multiplier
            local parryAccuracy = pingThreshold + math.max(speed / speedDivisor, 9.5)
            parryAccuracy = parryAccuracy + math.clamp(ping / 1000 * speed, 0, 30)
            if speed > 1500 then local m = 1 + (speed - 1500) / 1000; parryAccuracy = parryAccuracy * math.clamp(m, 1.5, 3.5) end

            local dirToPlayer = (LocalPlayer.Character.PrimaryPart.Position - ball.Position).Unit
            local dotToPlayer = dirToPlayer:Dot(velocity.Unit)
            if ballTarget ~= LocalPlayer.Name and dotToPlayer < 0.1 then continue end

            if ball:FindFirstChild("AeroDynamicSlashVFX") then pcall(function() ball.AeroDynamicSlashVFX:Destroy() end); det.__aerodynamic_time = tick() end
            if Runtime and Runtime:FindFirstChild("Tornado") then local tornadoTime = (Runtime.Tornado:GetAttribute("TornadoTime") or 1) + 0.314159; if (tick() - Sys.__tornado_time) < tornadoTime then continue end end
            if isCurvedMixed() and ballTarget == LocalPlayer.Name then continue end
            if ball:FindFirstChild("ComboCounter") then continue end
            if LocalPlayer.Character.PrimaryPart:FindFirstChild("SingularityCape") then continue end
            if Sys.__infinity_active then continue end
            if isParryOnCooldown() then continue end

            local closestPlayer = riverGetClosest()
            if closestPlayer and not Sys.__antidot_parried then
                local playerDist = (LocalPlayer.Character.PrimaryPart.Position - closestPlayer.PrimaryPart.Position).Magnitude
                if playerDist <= 30 and dotToPlayer > 0.75 then
                    if ballTarget == LocalPlayer.Name and distance <= 30 then
                        doFire(); parriedBalls[ballId] = true; Sys.__antidot_parried = true
                    end
                end
            end

            if ballTarget == LocalPlayer.Name and distance <= parryAccuracy then
                doFire(); parriedBalls[ballId] = true
            end
        end

                if trainingBall then
            local tz = trainingBall:FindFirstChild("zoomies")
            if tz then
                local tbId = trainingBall:GetDebugId()
                trainingBall:GetAttributeChangedSignal("target"):Once(function() Sys.__training_parried = false; parriedBalls[tbId] = nil end)
                if not parriedBalls[tbId] then
                    local bt = trainingBall:GetAttribute("target"); local spd = tz.VectorVelocity.Magnitude
                    local dist = LocalPlayer:DistanceFromCharacter(trainingBall.Position)
                    local ping2 = Stats.Network.ServerStatsItem["Data Ping"]:GetValue(); local pingT = math.clamp(ping2 / 10, 5, 17)
                    local csd = math.min(math.max(spd - 9.5, 0), 650); local spdDiv = (2.5 + csd * 0.002) * Speed_Divisor_Multiplier
                    local pa = pingT + math.max(spd / spdDiv, 9.5) + math.clamp(ping2 / 1000 * spd, 0, 30)
                    if spd > 1500 then local m2 = 1 + (spd - 1500) / 1000; pa = pa * math.clamp(m2, 1.5, 3.5) end
                    if bt == LocalPlayer.Name and dist <= pa then doFire(); parriedBalls[tbId] = true end
                end
            end
        end
    end

        if autoParryEnabled and LocalPlayer.Character and LocalPlayer.Character.PrimaryPart then
        if not Alive or LocalPlayer.Character.Parent ~= Alive then return end

        local now = tick()
        if now - (Sys.__last_spam_check or 0) < 0.008 then return end
        Sys.__last_spam_check = now

        local ball = nil
        if Balls then for _, v in ipairs(Balls:GetChildren()) do if v:GetAttribute("realBall") then ball = v; break end end end
        if not ball then return end; local zoomies = ball:FindFirstChild("zoomies"); if not zoomies then return end

        if now - (Sys.__target_check_time or 0) > 0.1 then
            Sys.__target_check_time = now; local ce = riverGetClosest()
            if ce then
                if Sys.__spam_target then
                    if not Sys.__spam_target.Parent or not Sys.__spam_target:FindFirstChild("Humanoid") or Sys.__spam_target.Humanoid.Health <= 0 then Sys.__spam_target = nil end
                end
                if not Sys.__spam_target or (now - (Sys.__spam_target_time or 0) > 1) then Sys.__spam_target = ce; Sys.__spam_target_time = now end
            end
        end

        local ballTarget = ball:GetAttribute("target"); if not ballTarget then return end
        local vel = ball.AssemblyLinearVelocity or Vector3.zero; local speed = vel.Magnitude; if speed < 5 then return end
        local hr = LocalPlayer.Character.PrimaryPart; local dir = (hr.Position - ball.Position).Unit; local dot = dir:Dot(vel.Unit)
        local ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue(); local pingThreshold = math.clamp(ping / 10, 1, 16)
        local maxSpamDist = pingThreshold + math.min(speed / 6, 95); local maxSpeed = 5 - math.min(speed / 5, 5); local maxDot = math.clamp(dot, -1, 0) * maxSpeed; local spamAcc = maxSpamDist - maxDot

        local entity = Closest_Entity; if not entity or not entity.PrimaryPart then return end
        local entityDist = (hr.Position - entity.PrimaryPart.Position).Magnitude; local ballDist = LocalPlayer:DistanceFromCharacter(ball.Position); local targetDist = LocalPlayer:DistanceFromCharacter(entity.PrimaryPart.Position)

        if entityDist > maxSpamDist or ballDist > spamAcc or targetDist > maxSpamDist then return end
        if ballTarget == LocalPlayer.Name and targetDist > 30 and ballDist > 30 then return end
        if LocalPlayer.Character:GetAttribute("Pulsed") then return end

        local spamTarget = Sys.__spam_target; if not spamTarget then return end
        if ballTarget ~= spamTarget.Name and ballTarget ~= LocalPlayer.Name then return end

        if targetDist <= spamAcc and ballDist <= spamAcc then
            if Parries >= ParryThreshold then
                doFire()
                if Sys.__play_animation then riverPlayAnim() end
            end
        end
    end
end


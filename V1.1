function Antilag:SaveAndApply()
    antilagMaterials = {}; antilagDecalsTextures = {}; antilagParticles = {}
    for _, O in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if O:IsA("BasePart") and not (O:FindFirstAncestorWhichIsA("Model") and O:FindFirstAncestorWhichIsA("Model"):FindFirstChild("Humanoid")) then
                antilagMaterials[O] = O.Material; O.Material = Enum.Material.SmoothPlastic
            elseif O:IsA("Decal") or O:IsA("Texture") then
                table.insert(antilagDecalsTextures, {Object = O, Parent = O.Parent}); O.Parent = nil
            elseif (O:IsA("ParticleEmitter") or O:IsA("Smoke") or O:IsA("Fire") or O:IsA("Sparkles")) and O.Enabled then
                table.insert(antilagParticles, {Object = O, Enabled = O.Enabled}); O.Enabled = false
            end
        end)
    end
end

function Antilag:Restore()
    for O, mat in pairs(antilagMaterials) do pcall(function() if O and O.Parent then O.Material = mat end end) end
    for _, d in pairs(antilagDecalsTextures) do pcall(function() if d.Object and d.Parent then d.Object.Parent = d.Parent end end) end
    for _, p in pairs(antilagParticles) do pcall(function() if p.Object and p.Object.Parent then p.Object.Enabled = p.Enabled end end) end
    antilagMaterials = {}; antilagDecalsTextures = {}; antilagParticles = {}
end

function Antilag:HandleNew(d)
    if not antilagEnabled then return end
    pcall(function()
        if d:IsA("BasePart") and not (d:FindFirstAncestorWhichIsA("Model") and d:FindFirstAncestorWhichIsA("Model"):FindFirstChild("Humanoid")) then
            antilagMaterials[d] = d.Material; d.Material = Enum.Material.SmoothPlastic
        elseif d:IsA("Decal") or d:IsA("Texture") then
            table.insert(antilagDecalsTextures, {Object = d, Parent = d.Parent}); d.Parent = nil
        elseif (d:IsA("ParticleEmitter") or d:IsA("Smoke") or d:IsA("Fire") or d:IsA("Sparkles")) and d.Enabled then
            table.insert(antilagParticles, {Object = d, Enabled = d.Enabled}); d.Enabled = false
        end
    end)
end

function Antilag:Enable()
    if antilagEnabled then return end; antilagEnabled = true
    self:SaveAndApply()
    if antilagConnection then antilagConnection:Disconnect() end
    antilagConnection = workspace.DescendantAdded:Connect(function(d) self:HandleNew(d) end)
end

function Antilag:Disable()
    if not antilagEnabled then return end; antilagEnabled = false
    if antilagConnection then antilagConnection:Disconnect(); antilagConnection = nil end
    self:Restore()
end


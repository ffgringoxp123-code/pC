local ManualSpam = {}

function ManualSpam:Start()
    if manualSpamRunning then return end
    manualSpamRunning = true
    print("[ManualSpam] Started")

    if manualSpamConnection then manualSpamConnection:Disconnect() end
    manualSpamConnection = RunService.RenderStepped:Connect(function()
        if not manualSpamRunning or not LocalPlayer.Character or not LocalPlayer.Character.PrimaryPart then return end
        if not Alive or LocalPlayer.Character.Parent ~= Alive then return end
        doFire()
        if Sys.__play_animation then riverPlayAnim() end
    end)
end

function ManualSpam:Stop()
    manualSpamRunning = false
    if manualSpamConnection then
        manualSpamConnection:Disconnect()
        manualSpamConnection = nil
    end
    print("[ManualSpam] Stopped")
end


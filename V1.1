local lastClosestCheck = 0
local function riverGetClosest()
    local now = tick()
    if now - lastClosestCheck < 0.1 then return Closest_Entity end
    lastClosestCheck = now; local maxD = math.huge; local found = nil
    if not Alive then return nil end
